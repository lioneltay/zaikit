{
  "name": "@zaikit/core",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lioneltay/zaikit.git",
    "directory": "packages/core"
  },
  "homepage": "https://zaikit.dev",
  "bugs": "https://github.com/lioneltay/zaikit/issues",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^4",
    "@ai-sdk/provider": "^3",
    "@opentelemetry/api": "^1",
    "@zaikit/memory": "workspace:*",
    "@zaikit/utils": "workspace:*",
    "ai": "^6",
    "zod": "^4"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2",
    "@opentelemetry/sdk-trace-node": "^2",
    "@zaikit/memory-inmemory": "workspace:*",
    "@zaikit/typescript-config": "workspace:*",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
